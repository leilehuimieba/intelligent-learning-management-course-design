<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.CourseFocusStudy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/course_primary</item>
        <item name="colorPrimaryVariant">@color/course_primary_dark</item>
        <item name="colorSecondary">@color/course_secondary</item>
        <item name="android:statusBarColor">@color/course_primary_dark</item>
        <item name="android:windowBackground">@color/course_bg</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:textColorPrimary">@color/course_text</item>
        <item name="materialCardViewStyle">@style/Widget.CourseFocusStudy.CardView</item>
    </style>

    <style name="Widget.CourseFocusStudy.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/course_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">3dp</item>
    </style>
</resources>
